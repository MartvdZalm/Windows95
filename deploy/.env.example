# Copy to .env on the server: cp .env.example .env

CERTBOT_EMAIL=you@example.com

WINDOWS95_IMAGE=martvdzalm/windows95-angular-app:latest
KNIGHT_IMAGE=ghcr.io/martvdzalm/knight:latest
KNIGHT_ALLOWED_FRAME_ANCESTORS=https://martvanderzalm.com

# Used by "make remote-quick" from your laptop
DEPLOY_HOST=root@your-server-ip
DEPLOY_PATH=/opt/infra
