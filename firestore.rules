rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'WZTJW46HUeWOB4Tucx1ydsyozYD2';
    }

    // Public-read, no-write site configuration (safe default).
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: lock everything else down until explicitly opened.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

